# =========================================
# 1. DEPENDENCIES (Never upload these)
# =========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# =========================================
# 2. ENVIRONMENT VARIABLES (Critical Security)
# =========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# =========================================
# 3. PRODUCTION BUILD OUTPUTS (Vite/React)
# =========================================
dist/
dist-ssr/
build/
out/

# =========================================
